# Neon Postgres connection string (use the POOLED connection string)
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxxx-pooler.REGION.aws.neon.tech/neondb?sslmode=require"

# Secret used to sign the session cookie. Generate with:  openssl rand -base64 32
SESSION_SECRET="change-me-to-a-long-random-string"

# nTZS (NEDA Pay) disbursements — lets the admin pay prizes automatically.
# Leave NTZS_API_KEY blank to keep payouts manual. Confirm the exact base URL,
# field names and webhook signature against https://www.ntzs.co.tz/developers#withdrawals
NTZS_API_BASE="https://api.ntzs.co.tz"
NTZS_API_KEY=""
NTZS_WEBHOOK_SECRET=""
NTZS_CALLBACK_URL="https://your-site.netlify.app/api/webhooks/ntzs"
