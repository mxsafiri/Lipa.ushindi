# Neon Postgres connection string (use the POOLED connection string)
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxxx-pooler.REGION.aws.neon.tech/neondb?sslmode=require"

# Secret used to sign the session cookie. Generate with:  openssl rand -base64 32
SESSION_SECRET="change-me-to-a-long-random-string"

# nTZS (NEDA Pay) disbursements — lets the admin pay prizes automatically via
#   POST {NTZS_API_BASE}/api/v1/withdrawals
#   Authorization: Bearer NTZS_API_KEY
#   { userId: NTZS_USER_ID, amountTzs, phoneNumber }
# Leave NTZS_API_KEY blank to keep payouts manual.
NTZS_API_BASE="https://www.ntzs.co.tz"
NTZS_API_KEY=""
NTZS_USER_ID=""                 # your source nTZS account id (the wallet that gets burned)
NTZS_WEBHOOK_SECRET=""          # partner webhook secret, for /api/webhooks/ntzs
NTZS_CALLBACK_URL="https://your-site.netlify.app/api/webhooks/ntzs"
