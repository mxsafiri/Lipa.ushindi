# Neon Postgres connection string (use the POOLED connection string)
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxxx-pooler.REGION.aws.neon.tech/neondb?sslmode=require"

# Secret used to sign the session cookie. Generate with:  openssl rand -base64 32
SESSION_SECRET="change-me-to-a-long-random-string"

# nTZS (NEDA Pay) integration.
#  - Admin WALLET deposits (top up liquidity via mobile money) need ONLY
#    NTZS_API_KEY (base URL defaults to https://www.ntzs.co.tz):
#      POST {NTZS_API_BASE}/api/v1/partners/fund-treasury  { amountTzs, phoneNumber }
#  - Automated prize PAYOUTS additionally use NTZS_USER_ID (+ webhook secret):
#      POST {NTZS_API_BASE}/api/v1/withdrawals  { userId, amountTzs, phoneNumber }
NTZS_API_KEY=""
NTZS_API_BASE=""                # optional; defaults to https://www.ntzs.co.tz
NTZS_USER_ID=""                 # payouts only: source nTZS account that gets burned
NTZS_WEBHOOK_SECRET=""          # payouts only: partner webhook secret for /api/webhooks/ntzs
NTZS_CALLBACK_URL=""            # payouts only: https://your-site.netlify.app/api/webhooks/ntzs
